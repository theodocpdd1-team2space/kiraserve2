generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ChurchStatus {
  TRIAL
  ACTIVE
  INACTIVE
  MAINTENANCE
  SUSPENDED
}

enum ChurchRole {
  CHURCH_OWNER
  CHURCH_ADMIN
  DIVISION_COORDINATOR
  SERVANT
  MEMBER
}

enum ChurchMemberStatus {
  INVITED
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum MemberCodeMode {
  AUTO_GENERATE
  MANUAL
  APPROVAL_REQUIRED
}

enum DivisionMemberRole {
  COORDINATOR
  MEMBER
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  INACTIVE
  CANCELLED
}

enum PaymentStatus {
  DUMMY
  MANUAL_PENDING
  PAID
  FAILED
}

model User {
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  phone        String?
  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  churchMembers ChurchMember[]
}

model Church {
  id                   String         @id @default(cuid())
  name                 String
  slug                 String         @unique
  address              String?
  picName              String?
  picEmail             String?
  picPhone             String?
  status               ChurchStatus   @default(TRIAL)
  memberCodePrefix     String?
  memberCodeNextNumber Int            @default(1)
  memberCodeMode       MemberCodeMode @default(AUTO_GENERATE)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  members            ChurchMember[]
  divisions          ChurchDivision[]
  divisionMembers    DivisionMember[]
  subscriptions      Subscription[]
  activationRequests ActivationRequest[]
}

model ChurchMember {
  id         String             @id @default(cuid())
  churchId   String
  userId     String
  memberCode String?
  role       ChurchRole         @default(MEMBER)
  status     ChurchMemberStatus @default(ACTIVE)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @default(now()) @updatedAt

  church Church @relation(fields: [churchId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  divisionMembers DivisionMember[]

  @@unique([churchId, userId])
  @@unique([churchId, memberCode])
  @@index([churchId])
  @@index([userId])
  @@index([status])
  @@index([memberCode])
}

model ChurchDivision {
  id        String   @id @default(cuid())
  churchId  String
  name      String
  picName   String?
  picPhone  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  church Church @relation(fields: [churchId], references: [id], onDelete: Cascade)

  divisionMembers DivisionMember[]

  @@index([churchId])
}

model DivisionMember {
  id             String             @id @default(cuid())
  churchId       String
  divisionId     String
  churchMemberId String
  role           DivisionMemberRole @default(MEMBER)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @default(now()) @updatedAt

  church       Church         @relation(fields: [churchId], references: [id], onDelete: Cascade)
  division     ChurchDivision @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  churchMember ChurchMember   @relation(fields: [churchMemberId], references: [id], onDelete: Cascade)

  @@unique([divisionId, churchMemberId])
  @@index([churchId])
  @@index([divisionId])
  @@index([churchMemberId])
  @@index([role])
}

model Plan {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  price        Int
  billingCycle String   @default("monthly")
  description  String?
  features     Json?
  createdAt    DateTime @default(now())

  subscriptions      Subscription[]
  activationRequests ActivationRequest[]
}

model Subscription {
  id                 String             @id @default(cuid())
  churchId            String
  planCode            String
  status              SubscriptionStatus @default(TRIALING)
  trialStartedAt      DateTime?
  trialEndsAt         DateTime?
  currentPeriodStart  DateTime?
  currentPeriodEnd    DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  church Church @relation(fields: [churchId], references: [id], onDelete: Cascade)
  plan   Plan   @relation(fields: [planCode], references: [code])

  @@index([churchId])
  @@index([planCode])
}

model ActivationRequest {
  id               String        @id @default(cuid())
  churchId          String?
  planCode          String
  paymentStatus     PaymentStatus @default(DUMMY)
  activationStatus  String        @default("draft")
  rawPayload        Json?
  createdAt         DateTime      @default(now())

  church Church? @relation(fields: [churchId], references: [id], onDelete: SetNull)
  plan   Plan    @relation(fields: [planCode], references: [code])

  @@index([churchId])
  @@index([planCode])
}