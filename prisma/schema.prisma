generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ChurchStatus {
  TRIAL
  ACTIVE
  INACTIVE
  MAINTENANCE
  SUSPENDED
}

enum ChurchRole {
  CHURCH_OWNER
  CHURCH_ADMIN
  DIVISION_COORDINATOR
  SERVANT
  MEMBER
}

enum ChurchMemberStatus {
  INVITED
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum MemberCodeMode {
  AUTO_GENERATE
  MANUAL
  APPROVAL_REQUIRED
}

enum DivisionMemberRole {
  COORDINATOR
  MEMBER
}

enum ScheduleTableType {
  SINGLE_SESSION
  WEEKLY_BY_DATE
  MULTI_SERVICE_DAY
  MONTHLY_MULTI_SERVICE
  CUSTOM_TABLE
}

enum ScheduleVisibility {
  PRIVATE
  PUBLIC_LINK
}

enum DivisionScheduleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  INACTIVE
  CANCELLED
}

enum PaymentStatus {
  DUMMY
  MANUAL_PENDING
  PAID
  FAILED
}

model User {
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  phone        String?
  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  churchMembers ChurchMember[]
  authSessions  AuthSession[]
}

model Church {
  id                   String         @id @default(cuid())
  name                 String
  slug                 String         @unique
  address              String?
  picName              String?
  picEmail             String?
  picPhone             String?
  status               ChurchStatus   @default(TRIAL)
  memberCodePrefix     String?
  memberCodeNextNumber Int            @default(1)
  memberCodeMode       MemberCodeMode @default(AUTO_GENERATE)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  members            ChurchMember[]
  divisions          ChurchDivision[]
  divisionMembers    DivisionMember[]
  divisionSchedules  DivisionSchedule[]
  servingRoles       ServingRole[]
  memberServingRoles MemberServingRole[]
  subscriptions      Subscription[]
  activationRequests ActivationRequest[]
}

model ChurchMember {
  id         String             @id @default(cuid())
  churchId   String
  userId     String
  memberCode String?
  role       ChurchRole         @default(MEMBER)
  status     ChurchMemberStatus @default(ACTIVE)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @default(now()) @updatedAt

  church Church @relation(fields: [churchId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  divisionMembers    DivisionMember[]
  memberServingRoles MemberServingRole[]

  @@unique([churchId, userId])
  @@unique([churchId, memberCode])
  @@index([churchId])
  @@index([userId])
  @@index([status])
  @@index([memberCode])
}

model ChurchDivision {
  id        String   @id @default(cuid())
  churchId  String
  name      String
  picName   String?
  picPhone  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  church Church @relation(fields: [churchId], references: [id], onDelete: Cascade)

  divisionMembers DivisionMember[]
  servingRoles    ServingRole[]
  schedules       DivisionSchedule[]

  @@index([churchId])
}

model DivisionMember {
  id             String             @id @default(cuid())
  churchId       String
  divisionId     String
  churchMemberId String
  role           DivisionMemberRole @default(MEMBER)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @default(now()) @updatedAt

  church       Church         @relation(fields: [churchId], references: [id], onDelete: Cascade)
  division     ChurchDivision @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  churchMember ChurchMember   @relation(fields: [churchMemberId], references: [id], onDelete: Cascade)

  @@unique([divisionId, churchMemberId])
  @@index([churchId])
  @@index([divisionId])
  @@index([churchMemberId])
  @@index([role])
}

model Plan {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  price        Int
  billingCycle String   @default("monthly")
  description  String?
  features     Json?
  createdAt    DateTime @default(now())

  subscriptions      Subscription[]
  activationRequests ActivationRequest[]
}

model Subscription {
  id                 String             @id @default(cuid())
  churchId           String
  planCode           String
  status             SubscriptionStatus @default(TRIALING)
  trialStartedAt     DateTime?
  trialEndsAt        DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  church Church @relation(fields: [churchId], references: [id], onDelete: Cascade)
  plan   Plan   @relation(fields: [planCode], references: [code])

  @@index([churchId])
  @@index([planCode])
}

model ActivationRequest {
  id               String        @id @default(cuid())
  churchId         String?
  planCode         String
  paymentStatus    PaymentStatus @default(DUMMY)
  activationStatus String        @default("draft")
  rawPayload       Json?
  createdAt        DateTime      @default(now())

  church Church? @relation(fields: [churchId], references: [id], onDelete: SetNull)
  plan   Plan    @relation(fields: [planCode], references: [code])

  @@index([churchId])
  @@index([planCode])
}

model ServingRole {
  id         String   @id @default(cuid())
  churchId   String
  divisionId String
  name       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  church   Church         @relation(fields: [churchId], references: [id], onDelete: Cascade)
  division ChurchDivision @relation(fields: [divisionId], references: [id], onDelete: Cascade)

  memberServingRoles MemberServingRole[]

  @@unique([divisionId, name])
  @@index([churchId])
  @@index([divisionId])
}

model MemberServingRole {
  id             String   @id @default(cuid())
  churchId       String
  churchMemberId String
  servingRoleId  String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  church       Church       @relation(fields: [churchId], references: [id], onDelete: Cascade)
  churchMember ChurchMember @relation(fields: [churchMemberId], references: [id], onDelete: Cascade)
  servingRole  ServingRole  @relation(fields: [servingRoleId], references: [id], onDelete: Cascade)

  @@unique([churchMemberId, servingRoleId])
  @@index([churchId])
  @@index([churchMemberId])
  @@index([servingRoleId])
}

model AuthSession {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model LoginOtp {
  id         String    @id @default(cuid())
  email      String
  codeHash   String
  purpose    String    @default("LOGIN")
  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  consumedAt DateTime?

  @@index([email])
  @@index([expiresAt])
}


model DivisionSchedule {
  id          String                 @id @default(cuid())
  churchId    String
  divisionId  String
  title       String
  serviceDate DateTime
  startTime   String?
  endTime     String?
  location    String?
  notes       String?
  status      DivisionScheduleStatus @default(DRAFT)
  scheduleType ScheduleTableType       @default(WEEKLY_BY_DATE)
  visibility   ScheduleVisibility      @default(PRIVATE)
  shareSlug    String?                 @unique
  tableJson    Json?
  reminderEnabled Boolean              @default(false)
  reminderRules   Json?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @default(now()) @updatedAt

  church   Church         @relation(fields: [churchId], references: [id], onDelete: Cascade)
  division ChurchDivision @relation(fields: [divisionId], references: [id], onDelete: Cascade)

  @@index([churchId])
  @@index([divisionId])
  @@index([serviceDate])
  @@index([status])
}
